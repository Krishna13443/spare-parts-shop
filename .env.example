# Environment Variables for Production

# The port the server will run on (Render sets this automatically)
PORT=3001

# Your PostgreSQL Database URL (Render gives you this when you create a PostgreSQL instance)
# Format: postgres://user:password@hostname/dbname
DATABASE_URL=postgres://user:pass@host/db

# Production Deployment
# DATABASE_URL=postgres://user:password@host:port/database
# NODE_ENV=production

# WhatsApp Twilio Integration
# TWILIO_ACCOUNT_SID=your_account_sid
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# The secret key used to sign JWT tokens. Make this a long, random sequence of characters!
JWT_SECRET=super_secret_production_key_change_me_12345
